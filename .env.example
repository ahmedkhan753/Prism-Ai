# Contact form email delivery (Nodemailer over Gmail SMTP).
# The form POSTs to /api/contact, which emails the enquiry to GMAIL_USER.
#
# GMAIL_APP_PASSWORD is a 16-character Google "App Password" (NOT your normal
# password). Create one at: Google Account → Security → 2-Step Verification →
# App passwords. Enter it here without spaces.
#
# Copy this file to .env.local and fill both values. .env.local is gitignored.
# In production, set both in Vercel → Settings → Environment Variables.
#
# If either is missing, /api/contact logs the payload and returns ok:true
# (dev fallback) so local builds/tests pass without credentials.
GMAIL_USER=prism.ai.organization@gmail.com
GMAIL_APP_PASSWORD=

# ─── AI Chatbot (Gemini) ────────────────────────────────────────────────────
# Powers the floating chat widget via /api/chat.
# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
# (Free tier is sufficient for the chatbot.)
#
# Add to .env.local and set in Vercel → Settings → Environment Variables.
# NEVER use a NEXT_PUBLIC_ prefix — this key must stay server-side only.
# If missing, the widget returns a friendly dev-mode message so local builds
# work without a key.
GEMINI_API_KEY=
